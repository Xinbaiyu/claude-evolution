import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import fs from 'fs-extra';
import path from 'path';
import { migrateSuggestions } from '../../src/scripts/migrate-suggestions.js';
import * as observationManager from '../../src/memory/observation-manager.js';

vi.mock('../../src/config/loader.js', () => ({
  getEvolutionDir: () => '/tmp/test-evolution',
}));

vi.mock('../../src/utils/index.js', () => ({
  logger: {
    info: vi.fn(),
    error: vi.fn(),
    debug: vi.fn(),
  },
}));

describe('migrate-suggestions', () => {
  const testDir = '/tmp/test-evolution';
  const learnedDir = path.join(testDir, 'learned');
  const pendingPath = path.join(learnedDir, 'pending.json');
  const markerPath = path.join(learnedDir, '.migrated');

  beforeEach(async () => {
    await fs.ensureDir(learnedDir);
    await fs.ensureDir(path.join(testDir, 'memory', 'observations'));

    // Mock observation manager
    vi.spyOn(observationManager, 'loadActiveObservations').mockResolvedValue([]);
    vi.spyOn(observationManager, 'saveActiveObservations').mockResolvedValue();
  });

  afterEach(async () => {
    await fs.remove(testDir);
    vi.clearAllMocks();
  });

  it('should migrate pending.json to active.json', async () => {
    const suggestions = [
      {
        id: 'sugg-001',
        type: 'preference',
        item: {
          type: 'Code Style',
          description: 'Use const for immutable variables',
          frequency: 5,
          confidence: 0.85,
        },
        confidence: 0.85,
        createdAt: '2026-03-01T10:00:00Z',
        evidence: ['session-001', 'session-002'],
      },
    ];

    await fs.writeJson(pendingPath, suggestions);

    const result = await migrateSuggestions();

    expect(result.success).toBe(true);
    expect(result.migratedCount).toBe(1);
    expect(result.backupPath).toContain('pending.json.backup-');

    // Verify backup created
    expect(await fs.pathExists(result.backupPath!)).toBe(true);

    // Verify marker created
    expect(await fs.pathExists(markerPath)).toBe(true);

    // Verify saveActiveObservations called with correct data
    expect(observationManager.saveActiveObservations).toHaveBeenCalledWith(
      expect.arrayContaining([
        expect.objectContaining({
          id: 'sugg-001',
          type: 'preference',
          confidence: 0.85,
          mentions: 5,
          inContext: false,
        }),
      ])
    );
  });

  it('should handle empty pending.json', async () => {
    await fs.writeJson(pendingPath, []);

    const result = await migrateSuggestions();

    expect(result.success).toBe(true);
    expect(result.migratedCount).toBe(0);
    expect(result.error).toContain('No legacy data');
  });

  it('should handle missing pending.json', async () => {
    const result = await migrateSuggestions();

    expect(result.success).toBe(true);
    expect(result.migratedCount).toBe(0);
    expect(result.error).toContain('No legacy data');
  });

  it('should skip migration if already migrated', async () => {
    await fs.writeJson(markerPath, { migratedAt: '2026-03-15T10:00:00Z' });

    const result = await migrateSuggestions();

    expect(result.success).toBe(true);
    expect(result.migratedCount).toBe(0);
    expect(result.error).toContain('Already migrated');
  });

  it('should merge with existing observations', async () => {
    const existingObs = [
      {
        id: 'existing-001',
        type: 'preference',
        confidence: 0.9,
        mentions: 10,
        inContext: false,
      },
    ];

    vi.spyOn(observationManager, 'loadActiveObservations').mockResolvedValue(
      existingObs as any
    );

    const suggestions = [
      {
        id: 'sugg-001',
        type: 'pattern',
        item: {
          problem: 'Build fails',
          solution: 'Check TypeScript errors',
          occurrences: 3,
        },
        confidence: 0.75,
      },
    ];

    await fs.writeJson(pendingPath, suggestions);

    const result = await migrateSuggestions();

    expect(result.success).toBe(true);
    expect(result.migratedCount).toBe(1);

    // Verify merge happened
    expect(observationManager.saveActiveObservations).toHaveBeenCalledWith(
      expect.arrayContaining([
        expect.objectContaining({ id: 'existing-001' }),
        expect.objectContaining({ id: 'sugg-001' }),
      ])
    );
  });

  it('should preserve evidence and timestamps', async () => {
    const suggestions = [
      {
        id: 'sugg-001',
        type: 'workflow',
        item: {
          name: 'Git Commit',
          steps: ['Run tests', 'Commit', 'Push'],
          frequency: 8,
        },
        confidence: 0.92,
        createdAt: '2026-02-01T10:00:00Z',
        evidence: ['session-100', 'session-101', 'session-102'],
      },
    ];

    await fs.writeJson(pendingPath, suggestions);

    await migrateSuggestions();

    expect(observationManager.saveActiveObservations).toHaveBeenCalledWith(
      expect.arrayContaining([
        expect.objectContaining({
          evidence: ['session-100', 'session-101', 'session-102'],
          firstSeen: '2026-02-01T10:00:00Z',
          lastSeen: '2026-02-01T10:00:00Z',
          mentions: 8,
        }),
      ])
    );
  });
});
