{
  "name": "claude-evolution",
  "version": "0.2.0",
  "description": "Self-evolution system for Claude Code to learn from historical sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-evolution": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:web": "cd web/client && npm run build",
    "dev": "tsx watch src/cli/index.ts",
    "dev:server": "tsx watch web/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:http": "node test-http-api.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix"
  },
  "keywords": [
    "claude",
    "ai",
    "learning",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/diff": "^7.0.2",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "diff": "^8.0.3",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chokidar": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.8"
  }
}
